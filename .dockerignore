# =============================================================================
# Docker Ignore File - Optimized for Fast Builds
# =============================================================================
# 빌드 컨텍스트에서 제외할 파일/폴더
# 목표: 빌드 컨텍스트 50MB 이하로 유지
# =============================================================================

# =============================================================================
# 대용량 폴더 (최우선 제외)
# =============================================================================
# Python 가상환경 (1GB+)
**/.venv/
**/venv/
**/.virtualenv/
**/virtualenv/
**/.env/
**/env/
**/ENV/

# Node.js 의존성 (400MB+)
**/node_modules/

# 테스트용 Vector DB (394MB)
test_vector_db/

# 데이터 폴더
data/
dataCrawling/
**/chroma_data/

# =============================================================================
# Python 캐시 및 빌드 산출물
# =============================================================================
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/*.so
**/.Python
**/.pytest_cache/
**/.hypothesis/
**/*.egg-info/
**/.eggs/
**/dist/
**/build/
**/.mypy_cache/
**/.ruff_cache/

# =============================================================================
# Next.js 빌드 산출물
# =============================================================================
**/.next/
**/out/

# =============================================================================
# Git
# =============================================================================
.git/
.gitignore
.gitattributes

# =============================================================================
# IDE / 에디터
# =============================================================================
.vscode/
.idea/
**/*.swp
**/*.swo
**/.kiro/

# =============================================================================
# 테스트
# =============================================================================
**/coverage/
**/.coverage
**/htmlcov/
**/.tox/
**/.nox/
**/tests/
**/test_*.py
**/*_test.py

# =============================================================================
# 문서 (볼륨으로 마운트)
# =============================================================================
docs/
analytics/
**/*.ipynb
**/*.md
!README.md

# =============================================================================
# 환경 설정 파일
# =============================================================================
.env
.env.local
.env.*.local
.env.example
**/*.log

# =============================================================================
# 데이터 파일 (볼륨으로 마운트)
# =============================================================================
**/*.csv
**/*.xlsx
**/*.xls
**/*.pkl
**/*.pickle
**/*.parquet

# JSON (필수 설정 파일 제외)
*.json
!apps/frontend/package.json
!apps/frontend/package-lock.json
!apps/frontend/tsconfig.json

# =============================================================================
# 대용량 파일
# =============================================================================
**/*.html
**/*.pt
**/*.pth
**/*.h5
**/*.model
**/*.bin
**/*.onnx
**/*.safetensors

# =============================================================================
# 임시 파일
# =============================================================================
tmp/
temp/
**/*.tmp
**/*.temp
**/*.bak
**/*.old

# =============================================================================
# OS 파일
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Docker 관련 (이미지 내부에 불필요)
# =============================================================================
Dockerfile*
docker-compose*.yml
.docker/
.dockerignore

# =============================================================================
# 인프라 (빌드에 불필요)
# =============================================================================
infra/aws/
infra/terraform/
infra/cloudformation/

# =============================================================================
# 스크립트 (볼륨으로 마운트)
# =============================================================================
scripts/

# =============================================================================
# 기타
# =============================================================================
Makefile
*.sh
*.bat
*.ps1
debug_*.py
styles.css
