# =============================================================================
# Environment Variables Template
# =============================================================================
# 이 파일을 .env로 복사한 후 값을 채워주세요.
# Copy this file to .env and fill in the values.
#
# 변수 분류:
#   [REQUIRED] - 필수 설정 (도커 실행 시 반드시 필요)
#   [SECRET]   - 민감한 정보 (Git에 커밋하지 마세요)
#   [CONFIG]   - 일반 설정
# =============================================================================

# =============================================================================
# PostgreSQL Database
# =============================================================================
# [REQUIRED][SECRET] PostgreSQL 비밀번호
POSTGRES_PASSWORD=

# [CONFIG] PostgreSQL 연결 정보
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=realestate
POSTGRES_USER=postgres

# [CONFIG] PostgreSQL 연결 풀 설정 (RAG 서비스용)
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10

# [SECRET] Production: 전체 연결 문자열 (AWS RDS 등)
# DATABASE_URL=postgres://user:password@host:port/dbname

# =============================================================================
# Neo4j Graph Database
# =============================================================================
# [REQUIRED][SECRET] Neo4j 비밀번호
NEO4J_PASSWORD=

# [CONFIG] Neo4j 연결 정보
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j

# =============================================================================
# Redis Cache
# =============================================================================
# [CONFIG] Redis 연결 URL
REDIS_URL=redis://redis:6379/0

# [CONFIG] Redis 개별 설정 (대체용)
REDIS_HOST=redis
REDIS_PORT=6379

# =============================================================================
# Elasticsearch
# =============================================================================
# [CONFIG] Elasticsearch 연결 정보
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=listings

# =============================================================================
# OpenAI API
# =============================================================================
# [REQUIRED][SECRET] OpenAI API 키 (RAG 서비스에서 사용)
OPENAI_API_KEY=

# =============================================================================
# Django Backend Settings
# =============================================================================
# [SECRET] Django Secret Key
# 생성: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# [CONFIG] 디버그 모드 (프로덕션에서는 반드시 False)
DJANGO_DEBUG=True

# [CONFIG] 허용 호스트 (쉼표로 구분)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# =============================================================================
# CORS Settings
# =============================================================================
# [CONFIG] 허용되는 CORS Origin (쉼표로 구분)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Logging Configuration
# =============================================================================
# [CONFIG] 로그 포맷: 'json' (CloudWatch용) 또는 'standard' (개발용)
LOG_FORMAT=standard

# [CONFIG] 로그 레벨: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# [CONFIG] Django 전용 로그 레벨
DJANGO_LOG_LEVEL=INFO

# =============================================================================
# Frontend (Next.js) Settings
# =============================================================================
# [CONFIG] 클라이언트에서 사용할 백엔드 API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# [CONFIG] 서버 사이드에서 사용할 백엔드 API URL (Docker 내부)
SERVER_API_URL=http://backend:8000

# =============================================================================
# NextAuth Authentication
# =============================================================================
# [REQUIRED][SECRET] NextAuth JWT 서명용 시크릿
# 생성: openssl rand -base64 32
NEXTAUTH_SECRET=

# [CONFIG] NextAuth URL (프론트엔드 URL)
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# Google OAuth
# =============================================================================
# [SECRET] Google OAuth 클라이언트 ID
GOOGLE_CLIENT_ID=

# [SECRET] Google OAuth 클라이언트 시크릿
GOOGLE_CLIENT_SECRET=

# =============================================================================
# Kakao Map API
# =============================================================================
# [CONFIG] Kakao 지도 JavaScript API 키 (공개, 프론트엔드에서 사용)
NEXT_PUBLIC_KAKAO_MAP_KEY=

# [SECRET] Kakao REST API 키 (서버 사이드 데이터 임포트용)
KAKAO_API_KEY=

# =============================================================================
# VWorld API (부동산 중개업소 정보)
# =============================================================================
# [SECRET] VWorld API 키
VWORLD_API_KEY=

# [CONFIG] VWorld 도메인
VWORLD_DOMAIN=http://localhost