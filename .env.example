# =============================================================================
# Environment Variables Template for AWS ECS Deployment
# =============================================================================
# This file documents all required environment variables for the application.
# Copy this file to .env and fill in the values.
#
# Variables are categorized as:
#   [SECRET] - Sensitive credentials, store in AWS Secrets Manager
#   [CONFIG] - Non-sensitive configuration, store in SSM Parameter Store
# =============================================================================

# =============================================================================
# PostgreSQL Database
# =============================================================================
# [SECRET] Production: Use DATABASE_URL for AWS RDS connection string
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=

# [CONFIG] Development: Individual connection parameters (alternative to DATABASE_URL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=realestate
POSTGRES_USER=postgres
# [SECRET] Database password
POSTGRES_PASSWORD=

# =============================================================================
# Neo4j Graph Database
# =============================================================================
# [CONFIG] Neo4j connection URI
# Development: bolt://localhost:7687
# Production (AuraDB): neo4j+s://xxxxx.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687

# [CONFIG] Neo4j username (typically 'neo4j')
NEO4J_USER=neo4j

# [SECRET] Neo4j password
NEO4J_PASSWORD=

# =============================================================================
# Redis Cache
# =============================================================================
# [CONFIG] Redis connection URL
# Development: redis://localhost:6379/0
# Production (ElastiCache): redis://xxxxx.cache.amazonaws.com:6379/0
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Elasticsearch / OpenSearch
# =============================================================================
# [CONFIG] Elasticsearch/OpenSearch host
# Development: localhost
# Production (AWS OpenSearch): search-xxxxx.region.es.amazonaws.com
ELASTICSEARCH_HOST=localhost

# [CONFIG] Elasticsearch/OpenSearch port
ELASTICSEARCH_PORT=9200

# =============================================================================
# OpenAI API
# =============================================================================
# [SECRET] OpenAI API key for embeddings and LLM
OPENAI_API_KEY=

# =============================================================================
# Django Backend Settings
# =============================================================================
# [SECRET] Django secret key for cryptographic signing
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# [CONFIG] Debug mode (MUST be False in production)
DJANGO_DEBUG=False

# [CONFIG] Allowed hosts for Django (comma-separated)
# Example: api.example.com,www.example.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# CORS Settings
# =============================================================================
# [CONFIG] Allowed CORS origins (comma-separated)
# Example: https://example.com,https://www.example.com
# WARNING: Do not use '*' in production
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Logging Configuration
# =============================================================================
# [CONFIG] Log format: 'json' for CloudWatch, 'standard' for development
LOG_FORMAT=json

# [CONFIG] Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# [CONFIG] Django-specific log level
DJANGO_LOG_LEVEL=INFO

# =============================================================================
# Frontend (Next.js) Settings
# =============================================================================
# [CONFIG] Backend API URL for client-side requests
NEXT_PUBLIC_API_URL=http://localhost:8000

# [CONFIG] Backend API URL for server-side requests (Docker internal)
SERVER_API_URL=http://backend:8000

# =============================================================================
# NextAuth Authentication
# =============================================================================
# [SECRET] NextAuth secret for JWT signing
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# [CONFIG] NextAuth URL (your frontend URL)
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# Google OAuth
# =============================================================================
# [SECRET] Google OAuth client ID
GOOGLE_CLIENT_ID=

# [SECRET] Google OAuth client secret
GOOGLE_CLIENT_SECRET=

# =============================================================================
# Kakao Map API
# =============================================================================
# [CONFIG] Kakao Map JavaScript API key (public, used in frontend)
NEXT_PUBLIC_KAKAO_MAP_KEY=

# [SECRET] Kakao REST API key (for server-side data import)
KAKAO_API_KEY=

# =============================================================================
# VWorld API (부동산 중개업소 정보)
# =============================================================================
# [SECRET] VWorld API key
VWORLD_API_KEY=

# [CONFIG] VWorld domain
VWORLD_DOMAIN=
