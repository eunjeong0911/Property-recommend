{
  "_comment": "CloudFront Distribution Configuration for Real Estate Platform",
  "_usage": "이 파일은 CloudFront 설정 참조용입니다. AWS Console 또는 Terraform/CDK로 적용하세요.",
  
  "Origins": [
    {
      "Id": "ALB-Origin",
      "DomainName": "${ALB_DNS_NAME}",
      "CustomOriginConfig": {
        "HTTPPort": 80,
        "HTTPSPort": 443,
        "OriginProtocolPolicy": "https-only",
        "OriginSSLProtocols": ["TLSv1.2"],
        "OriginReadTimeout": 60,
        "OriginKeepaliveTimeout": 5
      }
    }
  ],

  "CacheBehaviors": [
    {
      "_comment": "Next.js 정적 자산 - 강캐시",
      "PathPattern": "/_next/static/*",
      "TargetOriginId": "ALB-Origin",
      "ViewerProtocolPolicy": "redirect-to-https",
      "CachePolicyId": "658327ea-f89d-4fab-a63d-7e88639e58f6",
      "Compress": true,
      "TTL": {
        "DefaultTTL": 31536000,
        "MaxTTL": 31536000,
        "MinTTL": 31536000
      }
    },
    {
      "_comment": "Django 정적 파일 - 캐시",
      "PathPattern": "/static/*",
      "TargetOriginId": "ALB-Origin",
      "ViewerProtocolPolicy": "redirect-to-https",
      "CachePolicyId": "658327ea-f89d-4fab-a63d-7e88639e58f6",
      "Compress": true,
      "TTL": {
        "DefaultTTL": 2592000,
        "MaxTTL": 31536000,
        "MinTTL": 86400
      }
    },
    {
      "_comment": "Backend API - 캐시 OFF (완전 패스스루)",
      "PathPattern": "/api/*",
      "TargetOriginId": "ALB-Origin",
      "ViewerProtocolPolicy": "redirect-to-https",
      "CachePolicyId": "4135ea2d-6df8-44a3-9df3-4b5a84be39ad",
      "OriginRequestPolicyId": "216adef6-5c7f-47e4-b989-5492eafa07d3",
      "AllowedMethods": ["GET", "HEAD", "OPTIONS", "PUT", "POST", "PATCH", "DELETE"],
      "Compress": false,
      "TTL": {
        "DefaultTTL": 0,
        "MaxTTL": 0,
        "MinTTL": 0
      }
    },
    {
      "_comment": "RAG API - 캐시 OFF + 스트리밍 지원 (SSE)",
      "PathPattern": "/rag/*",
      "TargetOriginId": "ALB-Origin",
      "ViewerProtocolPolicy": "redirect-to-https",
      "CachePolicyId": "4135ea2d-6df8-44a3-9df3-4b5a84be39ad",
      "OriginRequestPolicyId": "216adef6-5c7f-47e4-b989-5492eafa07d3",
      "ResponseHeadersPolicyId": "67f7725c-6f97-4210-82d7-5512b31e9d03",
      "AllowedMethods": ["GET", "HEAD", "OPTIONS", "PUT", "POST", "PATCH", "DELETE"],
      "Compress": false,
      "TTL": {
        "DefaultTTL": 0,
        "MaxTTL": 0,
        "MinTTL": 0
      }
    },
    {
      "_comment": "Reco API - 캐시 OFF",
      "PathPattern": "/reco/*",
      "TargetOriginId": "ALB-Origin",
      "ViewerProtocolPolicy": "redirect-to-https",
      "CachePolicyId": "4135ea2d-6df8-44a3-9df3-4b5a84be39ad",
      "OriginRequestPolicyId": "216adef6-5c7f-47e4-b989-5492eafa07d3",
      "AllowedMethods": ["GET", "HEAD", "OPTIONS", "PUT", "POST", "PATCH", "DELETE"],
      "Compress": false,
      "TTL": {
        "DefaultTTL": 0,
        "MaxTTL": 0,
        "MinTTL": 0
      }
    }
  ],

  "DefaultCacheBehavior": {
    "_comment": "Next.js SSR 페이지 - TTL 짧게 또는 0",
    "TargetOriginId": "ALB-Origin",
    "ViewerProtocolPolicy": "redirect-to-https",
    "CachePolicyId": "4135ea2d-6df8-44a3-9df3-4b5a84be39ad",
    "OriginRequestPolicyId": "216adef6-5c7f-47e4-b989-5492eafa07d3",
    "AllowedMethods": ["GET", "HEAD", "OPTIONS", "PUT", "POST", "PATCH", "DELETE"],
    "Compress": true,
    "TTL": {
      "DefaultTTL": 0,
      "MaxTTL": 0,
      "MinTTL": 0
    }
  },

  "ManagedPolicies": {
    "_comment": "AWS 관리형 정책 ID 참조",
    "CachingOptimized": "658327ea-f89d-4fab-a63d-7e88639e58f6",
    "CachingDisabled": "4135ea2d-6df8-44a3-9df3-4b5a84be39ad",
    "AllViewer": "216adef6-5c7f-47e4-b989-5492eafa07d3",
    "CORS-S3Origin": "88a5eaf4-2fd4-4709-b370-b4c650ea3fcf",
    "SecurityHeadersPolicy": "67f7725c-6f97-4210-82d7-5512b31e9d03"
  },

  "WAFWebACL": {
    "_comment": "WAF 설정 권장사항",
    "Rules": [
      "AWSManagedRulesCommonRuleSet",
      "AWSManagedRulesKnownBadInputsRuleSet",
      "AWSManagedRulesSQLiRuleSet",
      "RateBasedRule (2000 requests/5min)"
    ]
  }
}
